# PostgreSQL credentials (override config.yaml)
PGUSER=postgres
PGPASSWORD=
PGHOST=
PGPORT=
PGDATABASE=

# Vision LLM API key for image table extraction (OpenRouter by default)
OPENROUTER_API_KEY=sk-or-...

# Slack notifications (optional, no-op if not set)
SLACK_WEBHOOK_URL=

# Prefect scheduling (optional, defaults to 5th of month at 8am)
# UPDATE_CRON=0 8 5 * *
# PREFECT_API_URL=http://localhost:4200/api
